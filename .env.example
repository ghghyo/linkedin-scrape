# LinkedIn Scraper Configuration
# Rename this file to .env and fill in your values

# Database location
DB_PATH=data/linkedin_scraper.db

# Browser session storage (persistent login cookies)
SESSION_DIR=data/linkedin_session

# ClickUp Integration (Optional)
# Get your token from ClickUp Settings -> API
CLICKUP_API_TOKEN=your_clickup_token_here
CLICKUP_LIST_ID=your_list_id_here
CLICKUP_TEAM_ID=
CLICKUP_SPACE_ID=
CLICKUP_FOLDER_ID=

# Logging verbosity (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Scraping limits (Tune these to stay safe from LinkedIn detection)
MAX_PAGES_PER_QUERY=3
MAX_POSTS_TO_EXPAND=20
DELAY_MIN_SECONDS=2
DELAY_MAX_SECONDS=8

# Browser visibility
# ALWAYS keep this as false if you want to see the browser while it's working.
# Set to true only if you want the scraper to run invisibly in the background.
HEADLESS=false
