{
  "manifest_version": 3,
  "name": "Gemini Comment Generator",
  "version": "1.3",
  "description": "AI-powered comment suggestions. Bulk mode for LinkedIn feeds. Click icon or Ctrl+Q to open side panel.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/",
    "https://www.linkedin.com/*",
    "https://*.supabase.co/*"
  ],
  "action": {
    "default_icon": {
      "16": "images/icon16.png"
    },
    "default_title": "Open Gemini Comment Generator"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Q",
        "mac": "Command+Q"
      },
      "description": "Open Gemini Comment Generator"
    }
  },
  "icons": {
    "16": "images/icon16.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "prompts/*.txt"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}